# Toolchain build configuration consumed by scripts/build-toolchain.sh.

LLVM_REPO=https://github.com/llvm/llvm-project.git
LLVM_REF=llvmorg-20.1.2

ZIG_REPO=https://codeberg.org/ziglang/zig
ZIG_REF=0.15.2

# Bootstrap zlib source used for static libz linking.
ZLIB_REPO=https://github.com/madler/zlib.git
ZLIB_REF=v1.3.1

# Optional support linker included in payload.
BUILD_MOLD=1
MOLD_REPO=https://github.com/rui314/mold.git
MOLD_REF=v2.4.0

# Passed to Zig's CMake build.
TARGET_TRIPLE=native
TARGET_CPU=native

# Zig official release builds currently require broad LLVM backend coverage.
# Leave LLVM_TARGETS_TO_BUILD unset to use LLVM's default full target set.
# LLVM_TARGETS_TO_BUILD=""

# Optional LLVM runtimes in LLVM build.
LLVM_ENABLE_RUNTIMES=compiler-rt
COMPILER_RT_RUNTIME_TARGETS="x86_64-unknown-linux-gnu;aarch64-unknown-linux-gnu"
COMPILER_RT_BUILTIN_TARGETS="x86_64-unknown-linux-gnu;aarch64-unknown-linux-gnu"
COMPILER_RT_BUILD_PROFILE=ON

# llvm/tools selections used at LLVM configure time.
LLVM_REQUIRED_TOOLS="llvm-ar llvm-config llvm-cov llvm-cxxfilt llvm-mca llvm-nm llvm-objcopy llvm-objdump llvm-profdata llvm-ranlib llvm-symbolizer llvm-xray"

TOOLCHAIN_NAME=zig-llvm-toolchain
PAYLOAD_NAME=ziggurat-bin

# Used only when a release archive basename override is not provided.
# Set to 1 only if you intentionally want the internal llvm+zig toolchain archive.
# Default behavior is release payload only (`ziggurat-<zig-version>.tar.xz`).
# EMIT_TOOLCHAIN_ARCHIVE=1

# Packaging mode for optional internal llvm+zig archive.
#   minimal => keep selected llvm bins/libs + compiler-rt runtime tree
#   full    => keep entire llvm install prefix
LLVM_PACKAGE_MODE=minimal

# Space-delimited values used when LLVM_PACKAGE_MODE=minimal.
LLVM_BINARIES="clang clang++ ld.lld llvm-ar llvm-ranlib llvm-objcopy llvm-objdump llvm-symbolizer llvm-profdata llvm-cov"
LLVM_DIRS="lib/clang"
LLVM_LIB_GLOBS="lib/libclang*.a lib/liblld*.a lib/libz*.a lib/libLLVM*.a lib/libc++*.a lib/libc++*.so* lib/libunwind*.a lib/libunwind*.so*"

# Release payload (ziggurat-<zig-version>.tar.xz) content controls.
PAYLOAD_LLVM_BINARIES="ld.lld llvm-ar llvm-ranlib llvm-objcopy llvm-objdump llvm-symbolizer llvm-profdata llvm-cov llvm-cxxfilt llvm-lld llvm-mca llvm-nm llvm-xray clangd clang-format clang-tidy"
PAYLOAD_LLVM_DIRS="lib/clang"
PAYLOAD_LLVM_STATIC_LIBS="lib/libc++.a lib/libc++abi.a lib/libunwind.a lib/libz.a"
PAYLOAD_REQUIRE_MOLD=1
