# Zig source repository URL.
ZIG_GIT_URL=https://codeberg.org/ziglang/zig

# Zig release version to build from source (tag v<version> is used unless ZIG_GIT_REF is set).
# ZIG_VERSION=

# Optional explicit Zig git ref (tag/branch/commit). Leave unset for latest stable release behavior.
# ZIG_GIT_REF=

# Optional explicit LLVM git ref (for example llvmorg-20.1.2). Leave unset to infer from Zig release.
# LLVM_GIT_REF=

# Optional explicit LLVM semantic version (must match LLVM_GIT_REF when both are set).
# LLVM_VERSION=

# Mold release version (resolved as tag v<version> unless MOLD_GIT_REF is set).
MOLD_VERSION=2.40.1

# Optional explicit mold source repository URL.
# MOLD_GIT_URL=https://github.com/rui314/mold.git

# Optional explicit mold git ref (tag/branch/commit).
# MOLD_GIT_REF=

# LLVM runtimes to build.
RUNTIMES="compiler-rt;libcxx;libcxxabi;libunwind;openmp"

# Optional extra tools to include in dist/bin in addition to required core tools.
TOOLS="clang-format;clang-tidy;clangd;llvm-ar;llvm-cov;llvm-cxxfilt;llvm-lld;llvm-mca;llvm-nm;llvm-objcopy;llvm-objdump;llvm-profdata;llvm-ranlib;llvm-symbolizer;llvm-xray"

# Sanitizer families expected in output metadata/smoke checks.
SANITIZERS="asan;tsan;msan;ubsan;lsan;rtsan"

# Strip binaries during size-optimization stage (1=enabled, 0=disabled).
STRIP_BINARIES=1

# xz compression level/options used for release tarball compression.
XZ_COMPRESSION_LEVEL=-9e

# Optional LLVM CMake overrides.
# LLVM_ENABLE_PROJECTS=
# LLVM_ENABLE_RUNTIMES=
# LLVM_TARGETS_TO_BUILD=
